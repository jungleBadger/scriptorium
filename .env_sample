# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (local defaults) ---
PGHOST=localhost
PGPORT=5432
PGUSER=bible
PGPASSWORD=bible
PGDATABASE=bible
PGSSL=false

# --- Ollama / LLM (optional — Explore feature) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
# OLLAMA_TIMEOUT_MS=45000
# OLLAMA_HEALTH_TIMEOUT_MS=3500

# --- Embedder (optional) ---
# EMBED_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# --- TTS / voice.ai (optional — Read Aloud feature) ---
# VOICE_AI_API_KEY=
# VOICE_AI_MODEL_ENGLISH=voiceai-tts-v1-latest
# VOICE_AI_MODEL_MULTILINGUAL=voiceai-tts-multilingual-v1-latest

# --- Cloudflare R2 audio cache (optional — TTS caching) ---
# R2_URL=
# R2_ACCESS_KEY=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_SIGNED_URL_TTL_SECONDS=3600
